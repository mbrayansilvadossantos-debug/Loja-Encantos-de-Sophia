{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including role and address.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's role in the system." },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zip": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Order details including items, total, status, and delivery information.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID." },
        "userId": { "type": "string", "description": "ID of the user who placed the order." },
        "items": { "type": "array", "items": { "type": "object" }, "description": "List of items in the order." },
        "total": { "type": "number", "description": "Total price of the order." },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered"], "description": "Current status of the order." },
        "deliveryAddress": { "type": "object", "description": "Address where the order should be delivered." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the order was created." },
        "estimatedDeliveryDate": { "type": "string", "format": "date-time", "description": "Estimated delivery date." }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "Collection of user profiles." },
    "/orders/{orderId}": { "schema": "Order", "description": "Collection of orders." }
  }
}
